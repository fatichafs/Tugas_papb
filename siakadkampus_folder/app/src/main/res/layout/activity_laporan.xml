<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#F4F6FB"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Judul -->
        <TextView
            android:text="Laporan Keuangan"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#3F51B5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"/>

        <!-- Input Jumlah -->
        <EditText
            android:id="@+id/etJumlah"
            android:hint="Jumlah"
            android:inputType="number"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Spinner Jenis -->
        <Spinner
            android:id="@+id/spJenis"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Tombol -->
        <Button
            android:id="@+id/btnTambah"
            android:text="Tambah"
            android:layout_marginTop="10dp"
            android:backgroundTint="#3F51B5"
            android:textColor="#FFFFFF"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Hasil Laporan -->
        <TextView
            android:id="@+id/tvPemasukan"
            android:text="Total Pemasukan: Rp 0"
            android:textSize="16sp"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvPengeluaran"
            android:text="Total Pengeluaran: Rp 0"
            android:textSize="16sp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvSaldo"
            android:text="Saldo: Rp 0"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#3F51B5"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>
</ScrollView>